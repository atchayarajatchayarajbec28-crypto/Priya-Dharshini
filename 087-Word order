from collections import OrderedDict
n = int(sys.stdin.readline())
wordcounts = OrderedDict()
for _ in range(n):
    word = sys.stdin.readline().strip()
    wordcounts[word] = wordcounts.get(word, 0) + 1
print(len(wordcounts))
